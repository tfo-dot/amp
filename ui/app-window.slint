import { Button, HorizontalBox, VerticalBox, Slider, ScrollView, LineEdit } from "std-widgets.slint";
import { TrackSelector, TrackInfo } from "./trackselector.slint";

export struct GridItem {
    id: string,
    name: string,
    thumbnail: image,
    description: string,
    meta: string,
    series_name: string,
    is_folder: bool,
    index: int
}

export struct ProviderMetadata {
    id: string,
    name: string,
}

export struct ConfigFieldMetadata {
    key: string,
    label: string,
    is_password: bool,
    value: string,
}

export struct Episode {
    title: string,
    duration: string,
    index: int,
    resume_time: string,
}

export component PlayerWindow inherits Window {
    title: "AMP - Advanced Media Player";
    background: #0b0b0b;

    // Callbacks
    callback toggle_pause();
    callback skip_by(int);
    callback seek(float);
    callback user_activity();
    callback select_item(int);
    callback select_next_up(int);
    callback mark_as_played(int, bool);
    callback back();
    callback login(string, [ConfigFieldMetadata]);
    callback select_audio_track(int);
    callback select_subtitle_track(int);
    callback select_provider(string);
    callback logout();
    callback close_player();

    // Global State
    in-out property <string> current_screen: "provider_select";
    in property <[ProviderMetadata]> available_providers: [];
    in property <string> selected_provider_id: "";
    in-out property <[ConfigFieldMetadata]> config_fields: [];
    in property <string> error_message: "";
    in-out property <bool> is_loading: false;

    // Library Data
    in property <[GridItem]> breadcrumbs: [];
    in property <[GridItem]> current_items: [];
    in property <[GridItem]> next_up_list: [];
    in property <string> current_folder_name: "Library";

    // Player Properties
    in property <image> video_frame;
    in property <bool> is_paused: false;
    in property <float> progress: 0.0;
    in property <string> time_pos: "00:00";
    in property <string> duration: "00:00";
    in property <bool> controls_visible: true;
    
    in property <[TrackInfo]> audio_tracks: [];
    in property <[TrackInfo]> subtitle_tracks: [];
    in property <string> audio_track_name: "Default";
    in property <string> subtitle_track_name: "None";

    // Sizes exported to Rust
    out property <length> video_width: video_area.width;
    out property <length> video_height: video_area.height;

    // --- -1. PROVIDER SELECT SCREEN ---
    if (root.current_screen == "provider_select") : VerticalLayout {
        alignment: center;
        spacing: 20px;
        padding: 40px;

        Text {
            text: "Select Media Provider";
            font-size: 32px;
            font-weight: 700;
            color: white;
            horizontal-alignment: center;
        }

        VerticalLayout {
            spacing: 15px;
            alignment: center;
            for provider in root.available_providers : Rectangle {
                width: 300px;
                height: 60px;
                background: prov-touch.has-hover ? #333 : #222;
                border-radius: 8px;
                border-width: 1px;
                border-color: #444;
                animate background { duration: 150ms; }

                Text {
                    text: provider.name;
                    color: white;
                    font-size: 18px;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }

                prov-touch := TouchArea {
                    clicked => { root.select_provider(provider.id); }
                }
            }
        }
    }

    // --- 0. LOGIN SCREEN ---
    if (root.current_screen == "login") : VerticalLayout {
        alignment: center;
        spacing: 30px;
        padding: 40px;

        Text {
            text: "Connect to " + root.selected_provider_id;
            font-size: 32px;
            font-weight: 700;
            color: white;
            horizontal-alignment: center;
        }

        Rectangle {
            width: 450px;
            background: #1a1a1a;
            border-radius: 12px;
            padding: 30px;

            VerticalLayout {
                spacing: 20px;
                padding: 20px;

                for field[i] in root.config_fields : VerticalLayout {
                    spacing: 8px;
                    Text { text: field.label; color: #aaa; font-size: 14px; }
                    LineEdit {
                        text: field.value;
                        input-type: field.is_password ? password : text;
                        edited(val) => { root.config_fields[i].value = val; }
                    }
                }

                if (root.error_message != "") : Text {
                    text: root.error_message;
                    color: #ff4444;
                    font-size: 14px;
                    horizontal-alignment: center;
                }

                Button {
                    text: "Connect";
                    primary: true;
                    enabled: !root.is_loading;
                    clicked => { root.login(root.selected_provider_id, root.config_fields); }
                }

                Button {
                    text: "Cancel";
                    clicked => { root.current_screen = "provider_select"; }
                }
            }
        }
    }

    // --- 1. LIBRARY / TREE BROWSER SCREEN ---
    if (root.current_screen == "library") : VerticalLayout {
        padding: 40px;
        spacing: 20px;

        HorizontalLayout {
            alignment: space-between;
            HorizontalLayout {
                spacing: 20px;
                if (root.breadcrumbs.length > 0) : Button {
                    text: "← Back";
                    clicked => { root.back(); }
                }
                Text {
                    text: root.current_folder_name;
                    font-size: 32px;
                    font-weight: 700;
                    color: white;
                }
            }
            Button {
                text: "Logout";
                clicked => { root.logout(); }
            }
        }

        ScrollView {
            VerticalLayout {
                spacing: 30px;

                // Next Up - Only at root level
                if (root.breadcrumbs.length == 0 && root.next_up_list.length > 0) : VerticalLayout {
                    spacing: 10px;
                    Text {
                        text: "Next Up";
                        font-size: 24px;
                        font-weight: 600;
                        color: #ff9900;
                    }
                    
                    ScrollView {
                        height: 210px;
                        viewport-height: 200px;
                        HorizontalLayout {
                            padding-bottom: 10px;
                            spacing: 20px;
                            alignment: start;
                            for s[i] in root.next_up_list : Rectangle {
                                width: 260px;
                                height: 200px;
                                background: #1a1a1a;
                                border-radius: 8px;
                                clip: true;

                                VerticalLayout {
                                    Rectangle {
                                        height: 120px;
                                        Image {
                                            source: s.thumbnail;
                                            width: 100%;
                                            height: 100%;
                                            image-fit: contain;
                                        }
                                    }

                                    Rectangle {
                                        VerticalLayout {
                                            padding: 5px;
                                            Text {
                                                text: s.name;
                                                color: white;
                                                font-size: 14px;
                                                font-weight: 500;
                                                overflow: elide;
                                            }
                                            Text {
                                                text: s.series_name;
                                                color: #aaa;
                                                font-size: 12px;
                                                overflow: elide;
                                            }
                                            Text {
                                                text: s.description;
                                                color: #ff9900;
                                                font-size: 12px;
                                                overflow: elide;
                                            }
                                        }
                                    }
                                }

                                TouchArea {
                                    clicked => { root.select_next_up(i); }
                                }
                            }
                        }
                    }
                }

                // Current Folder Content
                VerticalLayout {
                    spacing: 10px;
                    Text {
                        text: "Items";
                        font-size: 24px;
                        font-weight: 600;
                        color: white;
                    }

                    GridLayout {
                        spacing: 20px;
                        for item[i] in root.current_items : Rectangle {
                            row: Math.floor(i / 4);
                            col: Math.mod(i, 4);
                            width: 220px;
                            height: item.is_folder ? 280px : 120px;
                            background: item-touch.has-hover ? #222 : #1a1a1a;
                            border-radius: 8px;
                            clip: true;
                            animate background { duration: 150ms; }

                            VerticalLayout {
                                if (item.is_folder) : Rectangle {
                                    height: 220px;
                                    Image {
                                        source: item.thumbnail;
                                        width: 100%;
                                        height: 100%;
                                        image-fit: contain;
                                    }
                                }

                                Rectangle {
                                    VerticalLayout {
                                        padding: 10px;
                                        Text {
                                            text: (item.is_folder ? "" : item.index + ". ") + item.name;
                                            color: white;
                                            font-size: 16px;
                                            font-weight: 500;
                                            overflow: elide;
                                        }
                                        if (!item.is_folder) : HorizontalLayout {
                                            Text {
                                                text: item.description;
                                                color: #aaa;
                                                font-size: 12px;
                                            }
                                            if (item.meta != "") : Text {
                                                text: " Stopped at " + item.meta;
                                                color: #ff9900;
                                                font-size: 12px;
                                            }
                                            Rectangle {} // spacer
                                            Button {
                                                text: "✓";
                                                width: 25px;
                                                height: 25px;
                                                clicked => { root.mark_as_played(i, true); }
                                            }
                                        }
                                    }
                                }
                            }

                            item-touch := TouchArea {
                                clicked => { root.select_item(i); }
                            }
                        }
                    }
                }
            }
        }
    }

    // --- 3. PLAYER SCREEN ---
    video_area := Rectangle {
        visible: root.current_screen == "player";
        width: 100%;
        height: 100%;
        background: black;

        Image {
            source: root.video_frame;
            width: 100%;
            height: 100%;
            image-fit: contain;
        }

        TouchArea {
            // Keep visibility on click
            clicked => { root.user_activity(); }
            // Move activity
            pointer-event(evt) => { root.user_activity(); }
        }

        // Overlay Controls
        if root.controls_visible : Rectangle {
            background: #00000088;
            height: 120px;
            width: 100%;
            y: parent.height - self.height;

            VerticalLayout {
                padding: 20px;
                spacing: 10px;

                // Progress Bar
                HorizontalLayout {
                    spacing: 15px;
                    Text { text: root.time_pos; color: white; vertical-alignment: center; }
                    Slider {
                        value: root.progress;
                        minimum: 0;
                        maximum: 100;
                        changed(val) => { root.seek(val); }
                    }
                    Text { text: root.duration; color: white; vertical-alignment: center; }
                }

                // Controls
                HorizontalLayout {
                    spacing: 20px;
                    alignment: center;

                    Button {
                        text: "← 10s";
                        clicked => { root.skip_by(-10); }
                    }

                    Button {
                        text: root.is_paused ? "▶" : "⏸";
                        width: 60px;
                        clicked => { root.toggle_pause(); }
                    }

                    Button {
                        text: "10s →";
                        clicked => { root.skip_by(10); }
                    }
                    
                    Rectangle { width: 40px; } // spacer

                    TrackSelector {
                        label: "Audio:";
                        tracks: root.audio_tracks;
                        current_name: root.audio_track_name;
                        select_track(id) => { root.select_audio_track(id); }
                    }

                    TrackSelector {
                        label: "Subtitles:";
                        tracks: root.subtitle_tracks;
                        current_name: root.subtitle_track_name;
                        select_track(id) => { root.select_subtitle_track(id); }
                    }

                    Rectangle { width: 40px; } // spacer

                    Button {
                        text: "Close";
                        clicked => { root.close_player(); }
                    }
                }
            }
        }
    }

    // Loading Overlay
    if (root.is_loading) : Rectangle {
        background: #000000aa;
        // This TouchArea covers the whole screen and swallows all clicks
        TouchArea { }
        
        VerticalLayout {
            alignment: center;
            spacing: 20px;
            Text {
                text: "Loading...";
                color: white;
                font-size: 24px;
                horizontal-alignment: center;
            }
        }
    }
}
