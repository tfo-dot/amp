import { Button, HorizontalBox, VerticalBox, Slider, ScrollView, LineEdit } from "std-widgets.slint";
import { TrackSelector, TrackInfo } from "./trackselector.slint";

export struct Series {
    name: string,
    thumbnail: image,
}

export struct ProviderMetadata {
    id: string,
    name: string,
}

export struct ConfigFieldMetadata {
    key: string,
    label: string,
    is_password: bool,
    value: string,
}

export struct PublicUser {
    name: string,
    id: string,
    has_password: bool,
    thumbnail: image,
}

export struct Episode {
    title: string,
    duration: string,
}

export component PlayerWindow inherits Window {
    title: "AMP - Advanced Media Player";
    background: #0b0b0b;

    // Callbacks
    callback toggle_pause();
    callback seek(float);
    callback user_activity();
    callback select_series(int);
    callback select_episode(int);
    callback back_to_series();
    callback login(string, [ConfigFieldMetadata]);
    callback select_audio_track(int);
    callback select_subtitle_track(int);
    callback select_provider(string);
    callback logout();

    // Global State
    in-out property <string> current_screen: "provider_select";
    in property <[ProviderMetadata]> available_providers: [];
    in property <string> selected_provider_id: "";
    in-out property <[ConfigFieldMetadata]> config_fields: [];
    in property <string> error_message: "";
    in property <bool> is_loading: false;

    // Library Data
    in property <[Series]> series_list: [];
    in property <[Episode]> episode_list: [];
    in property <string> selected_series_name: "";

    // Player Properties
    in property <image> video_frame;
    in property <bool> is_paused: false;
    in property <float> progress: 0.0;
    in property <string> time_pos: "00:00";
    in property <string> duration: "00:00";
    in property <bool> controls_visible: true;
    
    in property <[TrackInfo]> audio_tracks: [];
    in property <[TrackInfo]> subtitle_tracks: [];
    in property <string> audio_track_name: "Default";
    in property <string> subtitle_track_name: "None";

    // Sizes exported to Rust
    out property <length> video_width: video_area.width;
    out property <length> video_height: video_area.height;

    // --- -1. PROVIDER SELECT SCREEN ---
    if (root.current_screen == "provider_select") : VerticalLayout {
        alignment: center;
        spacing: 20px;
        padding: 40px;

        Text {
            text: "Select Media Provider";
            font-size: 32px;
            font-weight: 700;
            color: white;
            horizontal-alignment: center;
        }

        VerticalLayout {
            spacing: 15px;
            alignment: center;
            for provider in root.available_providers : Rectangle {
                width: 300px;
                height: 60px;
                background: #1a1a1a;
                border-radius: 8px;
                HorizontalLayout {
                    padding: 20px;
                    Text {
                        text: provider.name;
                        color: white;
                        font-size: 18px;
                        vertical-alignment: center;
                    }
                }
                TouchArea {
                    clicked => { root.select_provider(provider.id); }
                }
            }
        }
    }

    // --- 0. LOGIN SCREEN ---
    if (root.current_screen == "login") : VerticalLayout {
        alignment: center;
        spacing: 15px;
        padding: 20px;

        Text {
            text: "AMP - Login";
            font-size: 32px;
            font-weight: 700;
            color: white;
            horizontal-alignment: center;
        }

        Button {
            text: "← Change Provider";
            clicked => { root.current_screen = "provider_select"; }
        }

        Rectangle {
            background: #1a1a1a;
            border-radius: 12px;
            width: 400px;
            height: 480px;
            
            VerticalLayout {
                padding: 30px;
                spacing: 20px;

                VerticalLayout {
                    spacing: 15px;
                    for field[i] in root.config_fields : VerticalLayout {
                        spacing: 5px;
                        Text { text: field.label; color: #aaa; font-size: 14px; }
                        LineEdit {
                            text: field.value;
                            placeholder-text: field.label;
                            input-type: field.is_password ? password : text;
                            edited(val) => {
                                root.config_fields[i].value = val;
                            }
                        }
                    }
                }

                if (root.error_message != "") : Text {
                    text: root.error_message;
                    color: #ff4444;
                    font-size: 14px;
                    horizontal-alignment: center;
                }

                Button {
                    text: root.is_loading ? "Connecting..." : "Connect";
                    enabled: !root.is_loading;
                    primary: true;
                    clicked => {
                        root.login(root.selected_provider_id, root.config_fields);
                    }
                }
            }
        }
    }

    // --- 1. SERIES PICKER SCREEN ---
    if (root.current_screen == "series") : VerticalLayout {
        padding: 40px;
        spacing: 20px;

        HorizontalLayout {
            alignment: space-between;
            Text {
                text: "Your Library";
                font-size: 32px;
                font-weight: 700;
                color: white;
            }
            Button {
                text: "Logout";
                clicked => { root.logout(); }
            }
        }

        ScrollView {
            VerticalLayout {
                spacing: 20px;
                HorizontalLayout {
                    spacing: 20px;
                    alignment: start;
                    for s[i] in root.series_list : Rectangle {
                        width: 200px;
                        height: 300px;
                        background: #1a1a1a;
                        border-radius: 8px;
                        clip: true;

                        VerticalLayout {
                            Rectangle {
                                background: #2a2a2a;
                                height: 240px;
                                Image {
                                    source: s.thumbnail;
                                    width: 100%;
                                    height: 100%;
                                    image-fit: contain;
                                }
                            }
                            
                            Rectangle {
                                Text {
                                    padding: 10px;
                                    text: s.name;
                                    color: white;
                                    font-size: 16px;
                                    font-weight: 500;
                                    overflow: elide;
                                }
                            }
                        }

                        TouchArea {
                            clicked => { root.select_series(i); }
                        }
                    }
                }
            }
        }
    }

    // --- 2. EPISODE PICKER SCREEN ---
    if (root.current_screen == "episodes") : VerticalLayout {
        padding: 40px;
        spacing: 20px;

        HorizontalLayout {
            spacing: 20px;
            alignment: start;
            
            Button {
                text: "← Back";
                clicked => { root.back_to_series(); }
            }

            Text {
                text: root.selected_series_name;
                font-size: 32px;
                font-weight: 700;
                color: white;
            }
        }

        ScrollView {
            VerticalLayout {
                spacing: 10px;
                for ep[i] in root.episode_list : Rectangle {
                    height: 60px;
                    background: ep_touch.has-hover ? #222 : #1a1a1a;
                    border-radius: 4px;
                    animate background { duration: 150ms; }

                    HorizontalLayout {
                        padding-left: 20px;
                        padding-right: 20px;
                        spacing: 20px;

                        Text {
                            text: (i + 1) + ". " + ep.title;
                            color: white;
                            font-size: 18px;
                            vertical-alignment: center;
                        }

                        Rectangle {} // Spacer

                        Text {
                            text: ep.duration;
                            color: #aaa;
                            font-size: 14px;
                            vertical-alignment: center;
                        }
                    }

                    ep_touch := TouchArea {
                        clicked => { root.select_episode(i); }
                    }
                }
            }
        }
    }

    // --- 3. PLAYER SCREEN ---
    video_area := Rectangle {
        visible: root.current_screen == "player";
        width: 100%;
        height: 100%;
        background: black;

        Image {
            source: root.video_frame;
            width: 100%;
            height: 100%;
            image-fit: contain;
        }

        TouchArea {
            pointer-event(ev) => {
                if (ev.kind == PointerEventKind.move) {
                    root.user_activity();
                }
            }
            clicked => { root.user_activity(); }
        }

        // Top Navigation (Back Button)
        VerticalLayout {
            alignment: start;
            padding: 20px;
            opacity: root.controls_visible ? 1.0 : 0.0;
            animate opacity { duration: 250ms; }

            HorizontalLayout {
                Button {
                    text: "← Library";
                    clicked => { root.current_screen = "episodes"; }
                }
            }
        }

        // Overlay Controls
        VerticalLayout {
            alignment: end;
            
            Rectangle {
                height: 160px;
                background: #00000088;
                opacity: root.controls_visible ? 1.0 : 0.0;
                animate opacity { duration: 250ms; }
                
                TouchArea {
                    pointer-event(ev) => { root.user_activity(); }
                    clicked => { root.user_activity(); }
                }

                VerticalLayout {
                    padding-left: 30px;
                    padding-right: 30px;
                    padding-bottom: 20px;
                    spacing: 10px;

                    Slider {
                        minimum: 0.0;
                        maximum: 100.0;
                        value: root.progress;
                        changed(val) => { 
                            root.user_activity();
                            root.seek(val); 
                        }
                    }

                    HorizontalLayout {
                        spacing: 20px;
                        alignment: center;

                        // Audio Track Selector
                        TrackSelector {
                            label: "🔊";
                            current_name: root.audio_track_name;
                            tracks: root.audio_tracks;
                            select_track(id) => { root.select_audio_track(id); }
                        }

                        // Time Display
                        Text {
                            text: root.time_pos;
                            color: white;
                            vertical-alignment: center;
                            font-size: 16px;
                            font-weight: 500;
                        }

                        // Play/Pause Button
                        Rectangle {
                            width: 50px;
                            height: 50px;
                            border-radius: 25px;
                            background: touch-area.pressed ? #555 : (touch-area.has-hover ? #444 : #333);
                            animate background { duration: 150ms; }
                            
                            Text {
                                text: root.is_paused ? "▶" : "⏸";
                                color: white;
                                font-size: 24px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            touch-area := TouchArea {
                                clicked => { 
                                    root.user_activity();
                                    root.toggle_pause(); 
                                }
                            }
                        }

                        Text {
                            text: root.duration;
                            color: #ccc;
                            vertical-alignment: center;
                            font-size: 16px;
                            font-weight: 500;
                        }

                        // Subtitle Track Selector
                        TrackSelector {
                            label: "💬";
                            current_name: root.subtitle_track_name;
                            tracks: root.subtitle_tracks;
                            select_track(id) => { root.select_subtitle_track(id); }
                        }
                    }
                }
            }
        }
    }
}
