import { Button, HorizontalBox, VerticalBox, Slider, ScrollView, LineEdit } from "std-widgets.slint";
import { TrackSelector, TrackInfo } from "./trackselector.slint";

import { Player } from "./player.slint";

export struct GridItem {
    id: string,
    name: string,
    thumbnail: image,
    description: string,
    meta: string,
    series_name: string,
    is_folder: bool,
    index: int,
    season_index: int
}

export struct ProviderMetadata {
    id: string,
    name: string,
}

export struct ConfigFieldMetadata {
    key: string,
    label: string,
    is_password: bool,
    value: string,
}

export struct Episode {
    title: string,
    duration: string,
    index: int,
    resume_time: string,
}

component NavRectangle inherits Rectangle {
    in-out property <string> current_screen;

    in property <string> name;
    in property <string> initial; 

    height: 60px;
    background: root.current_screen == root.name ? #333 : transparent;
    border-radius: 8px;
    Text { text: root.initial; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
    TouchArea { clicked => { root.current_screen = root.name; } }
}

component ExtensionTile inherits Rectangle {
    callback select_provider(string);

    in property <ProviderMetadata> provider;

    width: 300px;
    height: 60px;
    background: prov-touch.has-hover ? #333 : #222;
    border-radius: 8px;
    border-width: 1px;
    border-color: #444;
    animate background { duration: 150ms; }

    Text {
        text: provider.name;
        color: white;
        font-size: 18px;
        font-weight: 600;
        vertical-alignment: center;
        horizontal-alignment: center;
    }

    prov-touch := TouchArea {
        clicked => { root.select_provider(provider.id); }
    }
}

export component PlayerWindow inherits Window {
    title: "AMP - Advanced Media Player";
    background: #0b0b0b;

    // Callbacks
    callback toggle_pause();
    callback skip_by(int);
    callback seek(float);
    callback user_activity();
    callback select_item(int);
    callback select_next_up(int);
    callback mark_as_played(int, bool);
    callback back();
    callback login(string, [ConfigFieldMetadata]);
    callback select_audio_track(int);
    callback select_subtitle_track(int);
    callback select_provider(string);
    callback close_player();
    callback search(string);
    callback select_search_result(int);

    callback next();
    callback previous();

    // Global State
    in-out property <string> current_screen: "provider_select";
    in property <[ProviderMetadata]> available_providers: [];
    in property <string> selected_provider_id: "";
    in-out property <[ConfigFieldMetadata]> config_fields: [];
    in property <string> error_message: "";
    in-out property <bool> is_loading: false;

    // Library Data
    in property <[GridItem]> current_items: [];
    in property <[GridItem]> next_up_list: [];
    in property <[GridItem]> search_results: [];
    in property <string> current_folder_name: "Library";
    in-out property <string> search_query: "";

    // Player Properties
    in property <image> video_frame;
    in property <bool> is_paused: false;
    in property <float> progress: 0.0;
    in property <string> time_pos: "00:00";
    in property <string> duration: "00:00";
    in property <bool> controls_visible: true;

    in property <bool> has_next: false;
    in property <bool> has_previous: false;

    in property <[TrackInfo]> audio_tracks: [];
    in property <[TrackInfo]> subtitle_tracks: [];
    in property <string> audio_track_name: "Default";
    in property <string> subtitle_track_name: "None";

    // Sizes exported to Rust
    out property <length> video_width: video_area.width;
    out property <length> video_height: video_area.height;

    HorizontalLayout {
        if (root.current_screen != "player") : Rectangle {
            width: 80px;
            background: #151515;
            VerticalLayout {
                padding: 10px;
                spacing: 20px;
                alignment: start;

                NavRectangle { current_screen <=> root.current_screen; name: "library"; initial: "H"; }
                NavRectangle { current_screen <=> root.current_screen; name: "search"; initial: "S"; }
                NavRectangle { current_screen <=> root.current_screen; name: "provider_select"; initial: "E"; }
            }
        }

        VerticalLayout {
            // --- -1. PROVIDER SELECT SCREEN ---
            if (root.current_screen == "provider_select") : VerticalLayout {
                spacing: 20px;
                padding: 40px;

                Text {
                    text: "Extensions";
                    font-size: 32px;
                    font-weight: 700;
                    color: white;
                }
                
                VerticalLayout {
                    width: 100%;
                    height: 100%;
                    spacing: 15px;

                    for provider in root.available_providers : ExtensionTile {
                        provider: provider;

                        select_provider(s) => root.select_provider(s);
                    }
                }
            }

            // --- 0. LOGIN SCREEN ---
            if (root.current_screen == "login") : VerticalLayout {
                alignment: center;
                spacing: 30px;
                padding: 40px;

                Text {
                    text: "Connect to " + root.selected_provider_id;
                    font-size: 32px;
                    font-weight: 700;
                    color: white;
                    horizontal-alignment: center;
                }

                Rectangle {
                    width: 450px;
                    background: #1a1a1a;
                    border-radius: 12px;

                    VerticalLayout {
                        spacing: 20px;
                        padding: 20px;

                        for field[i] in root.config_fields : VerticalLayout {
                            spacing: 8px;
                            Text { text: field.label; color: #aaa; font-size: 14px; }
                            LineEdit {
                                text: field.value;
                                input-type: field.is_password ? password : text;
                                edited(val) => { root.config_fields[i].value = val; }
                            }
                        }

                        if (root.error_message != "") : Text {
                            text: root.error_message;
                            color: #ff4444;
                            font-size: 14px;
                            horizontal-alignment: center;
                        }

                        Button {
                            text: "Connect";
                            primary: true;
                            enabled: !root.is_loading;
                            clicked => { root.login(root.selected_provider_id, root.config_fields); }
                        }

                        Button {
                            text: "Cancel";
                            clicked => { root.current_screen = "provider_select"; }
                        }
                    }
                }
            }

            // --- 1. LIBRARY / TREE BROWSER SCREEN ---
            if (root.current_screen == "library") : VerticalLayout {
                padding: 40px;
                spacing: 20px;

                HorizontalLayout {
                    alignment: space-between;
                    width: 100%;

                    HorizontalLayout {
                        spacing: 20px;
                        Text {
                            text: root.current_folder_name;
                            font-size: 32px;
                            font-weight: 700;
                            color: white;
                        }

                        if (root.current_folder_name != "Library") : Button {
                            text: "Back";
                            clicked => { root.back(); }
                        } 
                    }
                }

                ScrollView {
                    VerticalLayout {
                        width: 100%;

                        if (root.current_folder_name == "Library") : VerticalLayout {
                            spacing: 10px;

                            Text {
                                text: "Next Up";
                                font-size: 24px;
                                font-weight: 600;
                                color: #ff9900;
                            }

                            if (root.next_up_list.length == 0) : Text {
                                text: "No next items...";
                                font-size: 16px;
                                font-weight: 600;
                                color: white;
                            }

                            if (root.next_up_list.length > 0) : ScrollView {
                                HorizontalLayout {
                                    padding-bottom: 10px;
                                    spacing: 20px;
                                    alignment: start;
                                    
                                    for s[i] in root.next_up_list : Rectangle {
                                        width: 260px;
                                        height: 200px;
                                        background: #1a1a1a;
                                        border-radius: 8px;
                                        clip: true;

                                        VerticalLayout {
                                            Rectangle {
                                                height: 120px;
                                                
                                                Image {
                                                    source: s.thumbnail;
                                                    width: 100%;
                                                    height: 100%;
                                                    image-fit: contain;
                                                }
                                            }

                                            Rectangle {
                                                VerticalLayout {
                                                    padding: 5px;
                                                    
                                                    Text {
                                                        text: s.name;
                                                        color: white;
                                                        font-size: 14px;
                                                        font-weight: 500;
                                                        overflow: elide;
                                                    }
                                                    
                                                    Text {
                                                        text: s.series_name;
                                                        color: #aaa;
                                                        font-size: 12px;
                                                        overflow: elide;
                                                    }
                                                    
                                                    HorizontalLayout {
                                                        alignment: space-between;
                                                        
                                                        Text {
                                                            text: s.description;
                                                            color: #ff9900;
                                                            font-size: 12px;
                                                            overflow: elide;
                                                        }
                                                        
                                                        Text {
                                                            text: "Jellyfin";
                                                            color: #ff9900;
                                                            font-size: 12px;
                                                            overflow: elide;
                                                        }
                                                    }
                                                }
                                            }
                                        }

                                        TouchArea {
                                            clicked => { root.select_next_up(i); }
                                        }
                                    }
                                }
                            }
                        }

                        // Current Folder Content
                        if (root.current_folder_name != "Library") : VerticalLayout {
                            width: 100%;
                            height: 100%;
                            spacing: 10px;
                            
                            GridLayout {
                                spacing: 20px;
                                for item[i] in root.current_items : Rectangle {
                                    row: Math.floor(i / 4);
                                    col: Math.mod(i, 4);
                                    width: 220px;
                                    height: item.is_folder ? 280px : 120px;
                                    background: item-touch.has-hover ? #222 : #1a1a1a;
                                    border-radius: 8px;
                                    clip: true;
                                    animate background { duration: 150ms; }

                                    VerticalLayout {
                                        if (item.is_folder) : Rectangle {
                                            height: 220px;
                                            Image {
                                                source: item.thumbnail;
                                                width: 100%;
                                                height: 100%;
                                                image-fit: contain;
                                            }
                                        }

                                        Rectangle {
                                            VerticalLayout {
                                                padding: 10px;
                                                Text {
                                                    text: (item.is_folder ? "" : item.index + ". ") + item.name;
                                                    color: white;
                                                    font-size: 16px;
                                                    font-weight: 500;
                                                    overflow: elide;
                                                }
                                                if (!item.is_folder) : HorizontalLayout {
                                                    Text {
                                                        text: item.description;
                                                        color: #aaa;
                                                        font-size: 12px;
                                                    }
                                                    if (item.meta != "") : Text {
                                                        text: " Stopped at " + item.meta;
                                                        color: #ff9900;
                                                        font-size: 12px;
                                                    }
                                                    Rectangle {} // spacer
                                                    Button {
                                                        text: "✓";
                                                        width: 25px;
                                                        height: 25px;
                                                        clicked => { root.mark_as_played(i, true); }
                                                    }
                                                }
                                            }
                                        }
                                    }

                                    item-touch := TouchArea {
                                        clicked => { root.select_item(i); }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // --- 2. SEARCH SCREEN ---
            if (root.current_screen == "search") : VerticalLayout {
                padding: 40px;
                spacing: 20px;

                width: 100%;

                Text {
                    text: "Search";
                    font-size: 32px;
                    font-weight: 700;
                    color: white;
                }

                HorizontalLayout {
                    alignment: space-between;
                    spacing: 15px;
                    
                    LineEdit {
                        placeholder-text: "Search for series, movies or episodes...";
                        text: root.search_query;
                        edited(t) => { root.search_query = t; }
                        accepted(t) => { root.search(t); }
                    }

                    Button {
                        text: "Search";
                        primary: true;
                        clicked => { root.search(root.search_query); }
                    }
                }

                ScrollView {
                    GridLayout {
                        spacing: 20px;
                        for item[i] in root.search_results : Rectangle {
                            row: Math.floor(i / 4);
                            col: Math.mod(i, 4);
                            width: 220px;
                            height: 280px;
                            background: item-search-touch.has-hover ? #222 : #1a1a1a;
                            border-radius: 8px;
                            clip: true;

                            VerticalLayout {
                                Rectangle {
                                    height: 180px;
                                    Image {
                                        source: item.thumbnail;
                                        width: 100%;
                                        height: 100%;
                                        image-fit: contain;
                                    }
                                }
                                VerticalLayout {
                                    padding: 10px;
                                    Text { text: item.name; color: white; font-size: 14px; font-weight: 600; overflow: elide; }
                                    Text { text: item.description; color: #aaa; font-size: 12px; height: 30px; overflow: elide; }
                                }
                            }

                            item-search-touch := TouchArea {
                                clicked => { root.select_search_result(i); }
                            }
                        }
                    }
                }
            }
        }

        video_area := Player {
            visible: root.current_screen == "player";

            video_frame: root.video_frame;
            is_paused: root.is_paused;
            progress: root.progress;
            time_pos: root.time_pos;
            duration: root.duration;
            controls_visible: root.controls_visible;

            audio_tracks: root.audio_tracks;
            subtitle_tracks: root.subtitle_tracks;
            audio_track_name: root.audio_track_name;
            subtitle_track_name: root.subtitle_track_name;

            has_next: root.has_next;
            has_previous: root.has_previous;

            next() => root.next();
            previous => root.previous();

            toggle_pause => toggle_pause();
            skip_by(i) => skip_by(i);
            seek(f) => seek(f);
            user_activity => user_activity();
            back => back();
            select_audio_track(idx) => select_audio_track(idx);
            select_subtitle_track(idx) => select_subtitle_track(idx);
            close_player => close_player();
        }
    }

    // Loading Overlay
    if (root.is_loading) : Rectangle {
        background: #000000aa;
        // This TouchArea covers the whole screen and swallows all clicks
        TouchArea { }
        
        VerticalLayout {
            alignment: center;
            spacing: 20px;
            Text {
                text: "Loading...";
                color: white;
                font-size: 24px;
                horizontal-alignment: center;
            }
        }
    }
}
